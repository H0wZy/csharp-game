{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Godot: Launch Game",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "/home/h0wzy/.local/bin/godot",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--debug-collisions"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Godot: Launch Current Scene",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "/home/h0wzy/.local/bin/godot",
      "args": [
        "--path",
        "${workspaceFolder}",
        "--debug-collisions",
        "${file}"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Godot: Attach",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
